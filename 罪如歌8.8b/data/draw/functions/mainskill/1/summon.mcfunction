#清理
kill @e[type=marker,tag=draw]
#通知
tellraw @a[scores={dlc_ins=5}] [{"text":"良先生召喚出五種元素的怪物，每種敵人存活時將影響戰鬥","color": "aqua"}]
tellraw @a[scores={dlc_ins=5,draw.player.cs.all=..5}] [{"text":"金：所有怪物近戰傷害+40%/只","color": "aqua"}]
tellraw @a[scores={dlc_ins=5,draw.player.cs.all=..5}] [{"text":"木：所有敵人每秒恢復40點生命值/只（良先生受到治療效果翻倍）","color": "aqua"}]
tellraw @a[scores={dlc_ins=5,draw.player.cs.all=..5}] [{"text":"水：所有玩家獲得虛弱I/只","color": "aqua"}]
tellraw @a[scores={dlc_ins=5,draw.player.cs.all=..5}] [{"text":"火：所有怪物移動速度+40%/只","color": "aqua"}]
tellraw @a[scores={dlc_ins=5,draw.player.cs.all=..5}] [{"text":"土：所有敵人獲得抗性提升1級/只","color": "aqua"}]
tellraw @a[scores={dlc_ins=5,draw.player.cs.all=..5}] [{"text":"若怪物總數低於5,良先生將重新繪製","color": "aqua"}]
execute if score #dlc draw.bossskill.mainskill.type matches 1 run tellraw @a[scores={dlc_ins=5}] [{"text":"注意:良先生翻轉陰陽，影響戰鬥的因素由怪物的存活轉化爲怪物的死亡","color": "red"}]